<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Copy this file to `Secrets.plist` (same folder) and fill in your own Plaid
  sandbox credentials. `Secrets.plist` is git-ignored and must never be committed.
-->
<plist version="1.0">
<dict>
	<key>PlaidClientID</key>
	<string>YOUR_PLAID_CLIENT_ID</string>
	<key>PlaidSecret</key>
	<string>YOUR_PLAID_SANDBOX_SECRET</string>
</dict>
</plist>
