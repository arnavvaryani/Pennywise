// Secrets.swift.example
// Pennywise
//
// Copy this file to Secrets.swift and fill in your credentials.
// Secrets.swift is gitignored and must never be committed.

enum Secrets {
    enum Plaid {
        static let clientID = "your-plaid-client-id"
        static let secret = "your-plaid-secret"

        // Use "https://sandbox.plaid.com" for development/testing.
        // Switch to "https://production.plaid.com" for the App Store release.
        static let baseURL = "https://sandbox.plaid.com"
    }
}
