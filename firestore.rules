rules_version = '2';

// Pennywise Firestore security rules.
//
// The app stores all financial data under `users/{userId}/...`. These rules
// enforce that a signed-in user can only ever read or write documents under
// their OWN user id — the server, not the client, is the source of truth for
// access control. Deploy with: `firebase deploy --only firestore:rules`.
service cloud.firestore {
  match /databases/{database}/documents {

    // A request is allowed only when authenticated AND operating on its own tree.
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // All financial sub-collections (accounts, transactions, budgetCategories,
      // monthlySummaries, etc.) inherit the same owner-only rule.
      match /{document=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
